VITE_API_URL=http://127.0.0.1:8000

# Administrator awal. Isi sebelum backend pertama kali membuat users_store.json.
# Jika password dikosongkan, backend membuat password acak dan mencetaknya sekali
# pada log proses saat penyimpanan akun dibuat.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_NAME=Administrator
BOOTSTRAP_ADMIN_PASSWORD=

UPLOAD_DIR=backend/uploads/files
CHROMA_PATH=backend/chroma_db
CHROMA_COLLECTION=knowledge_base_multilingual_v1
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Hybrid retrieval
MIN_RESULT_SCORE=0.24
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_CANDIDATES=20
RERANKER_WEIGHT=0.25

# Evidence verification
ENABLE_EVIDENCE_VERIFICATION=true
MIN_EVIDENCE_SCORE=0.58
EVIDENCE_WEIGHT=0.25

# Strict answerability and unanswerable-question rejection
ENABLE_ANSWERABILITY_GATE=true
ANSWERABILITY_MIN_TOP_SCORE=0.50
ANSWERABILITY_MIN_BASE_SCORE=0.30
ANSWERABILITY_MIN_EVIDENCE_SCORE=0.58
ANSWERABILITY_MIN_SCORE_MARGIN=0.0
ANSWERABILITY_REQUIRE_SUPPORTED_EVIDENCE=true
ANSWERABILITY_REQUIRE_COHERENT_EVIDENCE=true
ANSWERABILITY_STRONG_RETRIEVAL_SCORE=0.75
ANSWERABILITY_STRONG_EXACT_COVERAGE=0.35
ANSWERABILITY_MAX_CONTEXTS=5
ANSWERABILITY_PRE_RERANK_VETO=true

# Conservative answer and citation confidence
MIN_ANSWER_CONFIDENCE=0.40
MIN_SOURCE_CONFIDENCE=0.30
MAX_GENERATION_CONTEXTS=3
CONTEXT_REDUNDANCY_THRESHOLD=0.82
CONTEXT_SECONDARY_SCORE_RATIO=0.72
MAX_SOURCE_CITATIONS=2

# Generated-answer grounding
ENABLE_GENERATION_GROUNDING_VALIDATION=true
GENERATION_MIN_CLAIM_SUPPORT=0.32
SOURCE_EXCERPT_MAX_CHARS=360

# Bahasa jawaban mengikuti pilihan ID atau EN dari UI. Mode AUTO hanya dipakai
# ketika klien secara eksplisit mengirim AUTO atau tidak mengirim pilihan bahasa.

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-custom:latest
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_PREDICT=640
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_RETRIES=1

# Provider selection: ollama | gemini | groq
DEFAULT_LLM_PROVIDER=ollama

# Gemini. Insert your own key locally. Never commit the real key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Groq. Insert your own key locally. Never commit the real key.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=120
GROQ_MAX_RETRIES=2

# Dataset-driven follow-up
ENABLE_DATASET_FOLLOW_UP=true
FOLLOW_UP_DATASET_PATH=evaluation/ground_truth.json
FOLLOW_UP_CORPUS_PATH=backend/uploads/files
FOLLOW_UP_REQUIRE_TOPIC_MATCH=true
FOLLOW_UP_MIN_SCORE=25.0
FOLLOW_UP_VERIFY_RETRIEVAL=true
FOLLOW_UP_VERIFY_MAX_CANDIDATES=3
FOLLOW_UP_VERIFICATION_TOP_K=5

# Autentikasi dan evaluasi
# Atur rahasia tetap pada deployment agar token tidak berubah saat berkas rahasia hilang.
LAPISAI_AUTH_SECRET=
LAPISAI_AUTH_TOKEN_TTL_SECONDS=43200

# Skrip evaluation/generation/build_generation_dataset.py memakai endpoint chat
# terproteksi. Gunakan token yang sudah ada, atau kredensial akun evaluasi.
LAPISAI_AUTH_TOKEN=
LAPISAI_EVAL_USERNAME=admin
LAPISAI_EVAL_PASSWORD=
LAPISAI_CHAT_URL=http://127.0.0.1:8000/api/chat
LAPISAI_LOGIN_URL=http://127.0.0.1:8000/api/auth/login
LAPISAI_HEALTH_URL=http://127.0.0.1:8000/health
