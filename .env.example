VITE_API_URL=http://127.0.0.1:8000

UPLOAD_DIR=backend/uploads/files
CHROMA_PATH=backend/chroma_db
CHROMA_COLLECTION=knowledge_base_multilingual_v1
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Final candidates below this score are discarded after reranking/evidence checks.
MIN_RESULT_SCORE=0.24

# Multilingual cross-encoder reranking. Semantic top 20 and BM25 top 20
# are merged, then reranked before top 5. The conservative 0.25 weight keeps
# the strong hybrid ranking dominant while allowing the reranker to correct it.
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_CANDIDATES=20
RERANKER_WEIGHT=0.25

# Verify that a retrieved chunk contains the concepts/numbers requested by the user.
ENABLE_EVIDENCE_VERIFICATION=true
MIN_EVIDENCE_SCORE=0.42
EVIDENCE_WEIGHT=0.25

# Reject the entire retrieval result when the corpus does not contain enough
# explicit evidence. This stage is separate from ranking.
ENABLE_ANSWERABILITY_GATE=true
ANSWERABILITY_MIN_TOP_SCORE=0.35
# The original hybrid score must pass this floor; reranker score alone is insufficient.
ANSWERABILITY_MIN_BASE_SCORE=0.22
ANSWERABILITY_MIN_EVIDENCE_SCORE=0.42
ANSWERABILITY_MIN_SCORE_MARGIN=0.0
ANSWERABILITY_REQUIRE_SUPPORTED_EVIDENCE=false
ANSWERABILITY_STRONG_RETRIEVAL_SCORE=0.68
ANSWERABILITY_STRONG_EXACT_COVERAGE=0.20
ANSWERABILITY_MAX_CONTEXTS=5
# A query rejected by baseline hybrid+evidence cannot be resurrected by reranking.
ANSWERABILITY_PRE_RERANK_VETO=false

# Final gates for generating an answer and displaying its sources.
MIN_ANSWER_CONFIDENCE=0.48
MIN_SOURCE_CONFIDENCE=0.24

# Retrieval may keep top-k, but generation receives only a compact evidence bundle.
MAX_GENERATION_CONTEXTS=3
CONTEXT_REDUNDANCY_THRESHOLD=0.82
CONTEXT_SECONDARY_SCORE_RATIO=0.72
MAX_SOURCE_CITATIONS=2

# Reject unsupported generated facts, retry once, then use extractive fallback.
ENABLE_GENERATION_GROUNDING_VALIDATION=true
GENERATION_MIN_CLAIM_SUPPORT=0.32

# Exact source excerpt stored with every citation.
SOURCE_EXCERPT_MAX_CHARS=360

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3-custom:latest
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_PREDICT=640
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_RETRIES=1

# LLM provider selection: ollama | gemini | openai
DEFAULT_LLM_PROVIDER=ollama

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# One plain-text follow-up selected only from closely related, answerable ground-truth items.
ENABLE_DATASET_FOLLOW_UP=true
FOLLOW_UP_DATASET_PATH=evaluation/ground_truth.json
FOLLOW_UP_CORPUS_PATH=backend/uploads/files
FOLLOW_UP_REQUIRE_TOPIC_MATCH=true
FOLLOW_UP_MIN_SCORE=25.0
FOLLOW_UP_VERIFY_RETRIEVAL=true
FOLLOW_UP_VERIFY_MAX_CANDIDATES=3
FOLLOW_UP_VERIFICATION_TOP_K=5
