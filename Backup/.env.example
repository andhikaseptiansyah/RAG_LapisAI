NODE_ENV=development
PORT=5000

FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://username:password@host:5432/database

DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# AI Provider
# Untuk sementara pakai Groq.
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT_MS=60000

# Embedding
# Groq dipakai untuk chat. Embedding sebaiknya dipisah.
# Untuk development awal, pakai fallback dulu.
EMBEDDING_PROVIDER=fallback
EMBEDDING_MODEL=fallback-hash-embedding
FALLBACK_EMBEDDING_DIMENSION=384

# RAG
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
RAG_MAX_CONTEXT_CHARS=6000

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,docx,txt